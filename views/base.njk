<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Tienda Prado{% endblock %}</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Open Sans', sans-serif;
            color: #333;
        }

        /* Barra superior MUSEO DEL PRADO */
        .top-bar {
            background-color: #f5f5f5;
            border-bottom: 1px solid #e0e0e0;
            font-size: 0.75rem;
            letter-spacing: 0.08em;
            color: #555;
        }
        .top-bar a {
            color: #555;
            text-decoration: none;
        }
        .top-bar a:hover {
            text-decoration: underline;
        }

        /* Logo central */
        .logo-area {
            text-align: center;
            padding: 18px 0 12px 0;
            border-bottom: 1px solid #e8e8e8;
        }
        .logo-area h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            letter-spacing: 0.2em;
            color: #222;
            margin: 0;
            font-weight: 400;
        }
        .logo-icons {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            align-items: center;
            gap: 16px;
            font-size: 1.15rem;
        }
        .logo-icons a {
            color: #333;
            text-decoration: none;
            position: relative;
        }
        .logo-icons .badge-carrito {
            position: absolute;
            top: -8px;
            right: -10px;
            background: #c00;
            color: #fff;
            border-radius: 50%;
            font-size: 0.65rem;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .lang-switch {
            font-size: 0.8rem;
            color: #666;
        }
        .lang-switch a { color: #333; text-decoration: none; }
        .lang-switch a:hover { text-decoration: underline; }

        /* Menú de categorías principal */
        .main-nav {
            border-bottom: 1px solid #e0e0e0;
            background: #fff;
        }
        .main-nav ul {
            list-style: none;
            display: flex;
            justify-content: center;
            gap: 0;
            margin: 0;
            padding: 0;
            flex-wrap: wrap;
        }
        .main-nav li a {
            display: block;
            padding: 12px 14px;
            font-size: 0.72rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #333;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }
        .main-nav li a:hover,
        .main-nav li a.active {
            color: #8b6914;
        }

        /* Sidebar de subcategorías */
        .sidebar-title {
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 2px solid #333;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }
        .sidebar-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .sidebar-links li {
            margin-bottom: 6px;
        }
        .sidebar-links li a {
            font-size: 0.82rem;
            color: #2a7ab5;
            text-decoration: none;
        }
        .sidebar-links li a:hover {
            text-decoration: underline;
        }

        /* Cards de producto */
        .product-card {
            border: none;
            transition: transform 0.2s, box-shadow 0.2s;
            height: 100%;
            background: #fff;
        }
        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 .4rem .8rem rgba(0,0,0,.1) !important;
        }
        .product-img {
            object-fit: contain;
            height: 260px;
            width: 100%;
            padding: 10px;
        }
        .product-card .card-body {
            text-align: center;
        }
        .product-card .card-title {
            font-size: 0.88rem;
            font-weight: 400;
            color: #333;
            line-height: 1.3;
        }
        .product-card .product-price {
            font-size: 0.95rem;
            color: #555;
            margin-top: 6px;
        }

        /* Filtros superiores */
        .filter-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .filter-bar .view-toggle a {
            color: #999;
            font-size: 1.1rem;
            margin-right: 6px;
            text-decoration: none;
        }
        .filter-bar .view-toggle a.active { color: #333; }
        .filter-bar select {
            font-size: 0.8rem;
            border: 1px solid #ccc;
            padding: 4px 8px;
        }
        .showing-info {
            font-size: 0.8rem;
            color: #777;
        }

        /* Vista lista */
        .list-item-img {
            width: 120px;
            height: 120px;
            object-fit: contain;
        }
        .list-item:hover {
            background: #fafafa;
        }

        /* Paginación estilo Tienda Prado */
        .pagination-prado {
            list-style: none;
            display: flex;
            gap: 6px;
            padding: 0;
            margin: 0;
        }
        .pagination-prado li a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border: 1px solid #ccc;
            color: #555;
            text-decoration: none;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }
        .pagination-prado li a:hover {
            border-color: #333;
        }
        .pagination-prado li.active a {
            border: 2px solid #333;
            font-weight: 700;
            color: #222;
        }

        main {
            min-height: calc(100vh - 250px);
        }

        footer {
            border-top: 1px solid #e0e0e0;
        }
    </style>
</head>
<body class="bg-white">

    <!-- 1. Barra superior: MUSEO DEL PRADO -->
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center py-1">
            <span>MUSEO DEL PRADO</span>
            <a href="#">IMAGE BANK</a>
        </div>
    </div>

    <!-- 2. Logo central + iconos -->
    <div class="logo-area">
        <div class="container position-relative">
            <a href="/" style="text-decoration:none;">
                <h1>TIENDA PRADO</h1>
            </a>
            <div class="logo-icons">
                <!-- Buscador (lupa SVG) -->
                <a href="#searchCollapse" data-bs-toggle="collapse" aria-label="Buscar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </a>
                <!-- Usuario: login o logout dinámico -->
                {% if usuario %}
                    <a href="#" onclick="if(confirm('¿Seguro que quieres cerrar la sesión?')) window.location='/logout'; return false;" aria-label="Cerrar sesión" title="Cerrar sesión ({{ usuario }})">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </a>
                {% else %}
                    <a href="/login" aria-label="Iniciar sesión" title="Iniciar sesión">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </a>
                {% endif %}
                <!-- Carrito (bolsa SVG) — abre offcanvas -->
                <a href="#" data-bs-toggle="offcanvas" data-bs-target="#carritoOffcanvas" aria-label="Carrito" id="btnCarrito">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    <span class="badge-carrito" id="badgeCarrito" style="{% if not total_carrito %}display:none{% endif %}">{{ total_carrito }}</span>
                </a>
                <span class="lang-switch"><a href="#">ES</a> | <a href="#">EN</a></span>
            </div>
        </div>
    </div>

    <!-- Buscador colapsable -->
    <div class="collapse" id="searchCollapse">
        <div class="container py-2">
            <form action="/buscar" method="GET" class="d-flex">
                <input class="form-control me-2" type="search" name="busqueda" placeholder="Buscar productos..." aria-label="Buscar" {% if busqueda %}value="{{ busqueda }}"{% endif %}>
                <button class="btn btn-dark btn-sm" type="submit">Buscar</button>
            </form>
        </div>
    </div>

    <!-- 3. Menú de categorías principal -->
    <nav class="main-nav">
        <div class="container">
            <ul>
                <li><a href="#">Libros</a></li>
                <li><a href="#">Exposiciones</a></li>
                <li><a href="#">Colaboraciones</a></li>
                <li><a href="/" class="active">Impresiones</a></li>
                <li><a href="#">Hogar</a></li>
                <li><a href="#">Papelería</a></li>
                <li><a href="#">Textil y complementos</a></li>
                <li><a href="#">Niños</a></li>
                <li><a href="#">Regalos y accesorios</a></li>
                <li><a href="#">Colecciones</a></li>
                <li><a href="#">Outlet</a></li>
            </ul>
        </div>
    </nav>

    <!-- Offcanvas del Carrito (lado derecho) -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="carritoOffcanvas" aria-labelledby="carritoLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title" id="carritoLabel" style="font-family:'Playfair Display',serif; letter-spacing:0.1em;">MI CESTA</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div id="carritoVacio" class="text-center py-5 text-muted" style="display:none;">
                <p>Tu cesta está vacía</p>
                <a href="/" class="btn btn-outline-dark btn-sm">Ver catálogo</a>
            </div>
            <div id="carritoItems"></div>
        </div>
        <div class="offcanvas-footer border-top p-3 bg-light" id="carritoFooter" style="display:none;">
            <div class="d-flex justify-content-between mb-2 align-items-center">
                <span class="text-muted" style="font-size:0.85rem;">Total artículos: <span id="carritoTotalCount" class="fw-bold text-dark">0</span></span>
                <span class="text-muted" style="font-size:0.85rem;">Impuestos incluidos</span>
            </div>
            <div class="d-flex justify-content-between mb-3 align-items-center">
                <strong style="font-size:1.1rem; font-family:'Playfair Display',serif;">TOTAL</strong>
                <strong style="font-size:1.2rem;" id="carritoTotalPrecio">0,00 €</strong>
            </div>
            <button id="btnTramitarPedido" class="btn btn-dark w-100 py-2 rounded-0" style="letter-spacing:0.05em; font-size:0.9rem;">TRAMITAR PEDIDO</button>
        </div>
    </div>

    <!-- HTML Template para cada item del carrito -->
    <template id="carritoItemTemplate">
        <div class="carrito-item d-flex align-items-center border-bottom p-3">
            <img src="" alt="" class="carrito-item-img me-3" style="width:60px; height:60px; object-fit:contain;">
            <div class="flex-grow-1 pe-2">
                <p class="mb-1 fw-bold text-truncate" style="font-size:0.85rem; max-width: 180px;" data-titulo></p>
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <div class="d-flex align-items-center border rounded">
                        <button class="btn btn-sm text-secondary p-0" style="width:24px; height:24px;" data-restar title="Restar uno">-</button>
                        <span class="mx-2 text-center" style="font-size:0.85rem; width:20px;" data-cantidad></span>
                        <button class="btn btn-sm text-secondary p-0" style="width:24px; height:24px;" data-sumar title="Añadir uno">+</button>
                    </div>
                    <div class="text-end">
                        <div class="text-muted" style="font-size:0.75rem;" data-precio-unidad></div>
                        <span class="fw-bold" style="font-size:0.95rem; color:#333;" data-subtotal></span>
                    </div>
                </div>
            </div>
            <button class="btn btn-sm btn-outline-danger border-0 p-1 ms-1" data-eliminar title="Eliminar del carrito">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
        </div>
    </template>

    <!-- Contenido Principal -->
    <main class="container my-4">
        {% if ErrorMensaje %}
            <div class="alert alert-danger" role="alert">
                {{ ErrorMensaje }}
            </div>
        {% endif %}

        {% block content %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-white text-center py-4 mt-auto">
        <div class="container">
            <p class="mb-0 text-muted" style="font-size:0.8rem;">© 2026 Tienda Prado SBW</p>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- JavaScript del carrito con DOM y template -->
    <script>
    (function() {
        const offcanvasEl = document.getElementById('carritoOffcanvas');
        const template = document.getElementById('carritoItemTemplate');
        const contenedor = document.getElementById('carritoItems');
        const vacioMsg = document.getElementById('carritoVacio');
        const footer = document.getElementById('carritoFooter');
        const totalCountEl = document.getElementById('carritoTotalCount');
        const badge = document.getElementById('badgeCarrito');

        // Cargar carrito cuando se abre el offcanvas
        offcanvasEl.addEventListener('show.bs.offcanvas', cargarCarrito);

        async function cargarCarrito() {
            contenedor.innerHTML = '';
            try {
                const resp = await fetch('/api/carrito');
                const data = await resp.json();

                if (data.items.length === 0) {
                    vacioMsg.style.display = 'block';
                    footer.style.display = 'none';
                } else {
                    vacioMsg.style.display = 'none';
                    footer.style.display = 'block';
                    totalCountEl.textContent = data.total_carrito;
                    document.getElementById('carritoTotalPrecio').textContent = `${parseFloat(data.total_precio).toFixed(2).replace('.', ',')} €`;

                    data.items.forEach(item => {
                        // Clonar el template
                        const clon = template.content.cloneNode(true);
                        const img = clon.querySelector('img');
                        img.src = `/public/imagenes/${item.imagen.trim()}`;
                        img.alt = item.titulo.trim();

                        clon.querySelector('[data-titulo]').textContent = item.titulo.trim();
                        clon.querySelector('[data-titulo]').title = item.titulo.trim();
                        
                        clon.querySelector('[data-precio-unidad]').textContent = `${parseFloat(item.precio).toFixed(2).replace('.', ',')} € / ud`;
                        clon.querySelector('[data-cantidad]').textContent = item.cantidad;
                        clon.querySelector('[data-subtotal]').textContent = `${parseFloat(item.subtotal).toFixed(2).replace('.', ',')} €`;

                        // Botones + y -
                        const btnSumar = clon.querySelector('[data-sumar]');
                        btnSumar.addEventListener('click', () => actualizarCantidad(item.index, 1));

                        const btnRestar = clon.querySelector('[data-restar]');
                        btnRestar.addEventListener('click', () => actualizarCantidad(item.index, -1));

                        // Botón eliminar (papelera/cruz)
                        const btnEliminar = clon.querySelector('[data-eliminar]');
                        btnEliminar.addEventListener('click', () => eliminarItem(item.index));

                        contenedor.appendChild(clon);
                    });
                }
            } catch (err) {
                contenedor.innerHTML = '<p class="text-danger p-3">Error al cargar el carrito</p>';
            }
        }

        async function eliminarItem(index) {
            try {
                const resp = await fetch(`/api/carrito/${index}`, { method: 'DELETE' });
                const data = await resp.json();

                // Actualizar badge
                if (data.total_carrito > 0) {
                    badge.textContent = data.total_carrito;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }

                // Recargar la lista
                cargarCarrito();
            } catch (err) {
                console.error('Error eliminando item:', err);
            }
        }

        async function actualizarCantidad(index, delta) {
            try {
                const resp = await fetch(`/api/carrito/${index}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ delta })
                });
                const data = await resp.json();

                if (data.total_carrito > 0) {
                    badge.textContent = data.total_carrito;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }

                cargarCarrito();
            } catch (err) {
                console.error('Error actualizando cantidad:', err);
            }
        }

        // Tramitar pedido
        const btnTramitar = document.getElementById('btnTramitarPedido');
        if (btnTramitar) {
            btnTramitar.addEventListener('click', async () => {
                btnTramitar.disabled = true;
                btnTramitar.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Procesando...';
                
                try {
                    const resp = await fetch('/api/carrito/checkout', { method: 'POST' });
                    if (resp.ok) {
                        // Ocultar el offcanvas
                        const bsOffcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('carritoOffcanvas'));
                        if (bsOffcanvas) bsOffcanvas.hide();

                        // Resetear botón de la cesta global
                        badge.style.display = 'none';
                        badge.textContent = '0';
                        
                        // Mostrar mensaje de éxito tipo Toast o Alert en la pantalla
                        const alertaHTML = `
                        <div class="alert alert-success alert-dismissible fade show mt-4 shadow-sm" role="alert" style="border-left: 5px solid #198754;">
                            <h4 class="alert-heading font-serif">¡Pedido completado!</h4>
                            <p class="mb-0">Gracias por tu compra en Tienda Prado. Hemos vaciado tu carrito y preparado todo para el envío.</p>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>`;
                        
                        // Lo insertamos justo al principio del contenedor principal
                        const container = document.querySelector('main .container') || document.querySelector('main');
                        if (container) {
                            container.insertAdjacentHTML('afterbegin', alertaHTML);
                            window.scrollTo({ top: 0, behavior: 'smooth' });
                        } else {
                            alert('¡Gracias por tu compra! Tu pedido se ha tramitado correctamente.');
                        }
                        
                        // Recargar la vista interna del carrito para que si lo abren esté vacío
                        cargarCarrito();
                    }
                } catch(err) {
                    console.error('Error al tramitar pedido:', err);
                } finally {
                    btnTramitar.disabled = false;
                    btnTramitar.innerHTML = 'TRAMITAR PEDIDO';
                }
            });
        }
    })();
    </script>
</body>
</html>

