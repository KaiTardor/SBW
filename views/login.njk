{% extends "base.njk" %}

{% block title %}Iniciar Sesión - Tienda Prado{% endblock %}

{% block content %}
    <div style="max-width:550px; margin:0 auto;">
    <h3 class="mb-4" style="font-family:'Open Sans',sans-serif; font-weight:300; font-size:1.3rem; color:#333;">
        Inicia sesión con tu cuenta
    </h3>

    {% if error %}
    <div class="alert alert-danger" role="alert" style="font-size:0.85rem;">
        Email o contraseña incorrectos. Inténtalo de nuevo.
    </div>
    {% endif %}

    <div class="border p-4 bg-white">
        <form method="POST" action="/login">
            <div class="mb-4">
                <label for="email" class="form-label" style="font-size:0.75rem; color:#8b6914; text-transform:uppercase; letter-spacing:0.03em;">Correo electrónico</label>
                <input type="email" class="form-control border-0 border-bottom rounded-0 px-0" id="email" name="email" required autofocus style="box-shadow:none;">
            </div>
            <div class="mb-3 position-relative">
                <label for="contraseña" class="form-label" style="font-size:0.75rem; color:#8b6914; text-transform:uppercase; letter-spacing:0.03em;">Contraseña</label>
                <input type="password" class="form-control border-0 border-bottom rounded-0 px-0" id="contraseña" name="contraseña" required minlength="5" style="box-shadow:none;">
                <span class="position-absolute" style="right:0; top:38px; cursor:pointer; color:#888;" onclick="let p=document.getElementById('contraseña'); p.type = p.type==='password'?'text':'password';">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </span>
                <small class="text-muted" style="font-size:0.7rem;">Longitud de al menos 5 caracteres</small>
            </div>

            <div class="text-center mt-4 mb-3">
                <a href="#" class="text-muted" style="font-size:0.82rem;">¿Has olvidado tu contraseña?</a>
            </div>

            <div class="text-center mb-2">
                <button type="submit" class="btn px-5 py-2" style="background:#555; color:#fff; font-size:0.85rem; letter-spacing:0.05em;">Iniciar sesión</button>
            </div>
        </form>
    </div>

    <div class="mt-4 mb-5">
        <hr>
        <div class="text-center">
            <a href="#" style="color:#2a7ab5; font-size:0.9rem; text-decoration:none;">¿No tienes una cuenta? Créala aquí ›</a>
        </div>
    </div>
    </div>
{% endblock %}
